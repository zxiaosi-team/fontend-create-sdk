{
  "name": "@zxiaosi/create-sdk",
  "version": "0.5.2",
  "description": "A tool for generating @zxiaosi/sdk projects",
  "keywords": [
    "micro frontend",
    "qiankun"
  ],
  "license": "MIT",
  "author": "zxiaosi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zxiaosi-team/fontend-create-sdk.git"
  },
  "bin": {
    "create-sdk": "index.js"
  },
  "files": [
    "index.js",
    "dist",
    "templates"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "changelog": "npx git-cliff -o CHANGELOG.md"
  },
  "devDependencies": {
    "@clack/prompts": "^1.6.0",
    "cac": "^7.0.0",
    "picocolors": "^1.1.1",
    "tsdown": "^0.22.3"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
